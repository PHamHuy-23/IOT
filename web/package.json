{
  "name": "health-monitor-iot",
  "private": true,
  "workspaces": [
    "backend",
    "admin-web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w admin-web\"",
    "dev:backend": "npm run dev -w backend",
    "dev:web": "npm run dev -w admin-web",
    "db:push": "npm run db:push -w backend",
    "db:seed": "npm run db:seed -w backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
